            "date": 1778655574148,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"ko\">\r\n<head>\r\n<meta charset=\"UTF-8\" />\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n<title>Boardland Coordinate Picker</title>\r\n<style>\r\n  * {\r\n    box-sizing: border-box;\r\n  }\r\n\r\n  body {\r\n    margin: 0;\r\n    background: #1f1208;\r\n    color: #fff;\r\n    font-family: Consolas, monospace;\r\n    overflow: hidden;\r\n  }\r\n\r\n  .wrap {\r\n    width: 100vw;\r\n    height: 100vh;\r\n    display: grid;\r\n    grid-template-columns: 1fr 360px;\r\n  }\r\n\r\n  .stage {\r\n    position: relative;\r\n    width: 100%;\r\n    height: 100%;\r\n    display: grid;\r\n    place-items: center;\r\n    background: #2b180c;\r\n    overflow: hidden;\r\n  }\r\n\r\n  .board-box {\r\n    position: relative;\r\n    width: min(100vw - 360px, calc(100vh * 16 / 9));\r\n    aspect-ratio: 16 / 9;\r\n    background: #000;\r\n  }\r\n\r\n  #board {\r\n    position: absolute;\r\n    inset: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    object-fit: fill;\r\n    user-select: none;\r\n    pointer-events: none;\r\n  }\r\n\r\n  .dot {\r\n    position: absolute;\r\n    width: 34px;\r\n    height: 34px;\r\n    border-radius: 50%;\r\n    background: rgba(255, 43, 43, 0.72);\r\n    border: 3px solid #fff;\r\n    transform: translate(-50%, -50%);\r\n    display: grid;\r\n    place-items: center;\r\n    font-size: 14px;\r\n    font-weight: 900;\r\n    color: #fff;\r\n    text-shadow: 0 2px 3px #000;\r\n    z-index: 5;\r\n  }\r\n\r\n  .panel {\r\n    height: 100vh;\r\n    padding: 14px;\r\n    background: #111;\r\n    border-left: 2px solid #444;\r\n    overflow: auto;\r\n  }\r\n\r\n  h1 {\r\n    margin: 0 0 10px;\r\n    font-size: 18px;\r\n  }\r\n\r\n  .btns {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: 8px;\r\n    margin-bottom: 10px;\r\n  }\r\n\r\n  button {\r\n    min-height: 40px;\r\n    border: 0;\r\n    border-radius: 8px;\r\n    background: #ffd45a;\r\n    color: #2a1600;\r\n    font-weight: 900;\r\n    cursor: pointer;\r\n  }\r\n\r\n  button.danger {\r\n    background: #ff6969;\r\n    color: #fff;\r\n  }\r\n\r\n  textarea {\r\n    width: 100%;\r\n    height: calc(100vh - 180px);\r\n    resize: none;\r\n    background: #000;\r\n    color: #8cff8c;\r\n    border: 1px solid #444;\r\n    border-radius: 8px;\r\n    padding: 10px;\r\n    font-size: 12px;\r\n    line-height: 1.45;\r\n  }\r\n\r\n  .info {\r\n    margin-bottom: 10px;\r\n    font-size: 13px;\r\n    color: #ddd;\r\n    line-height: 1.5;\r\n  }\r\n\r\n  .warn {\r\n    color: #ffcf5a;\r\n  }\r\n</style>\r\n</head>\r\n<body>\r\n<div class=\"wrap\">\r\n  <div class=\"stage\">\r\n    <div class=\"board-box\" id=\"boardBox\">\r\n      <img id=\"board\" src=\"./assets/board/board-main.webp\" alt=\"board\" />\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"panel\">\r\n    <h1>좌표 찍기</h1>\r\n    <div class=\"info\">\r\n      기준 좌표계: <b>1600 × 900</b><br>\r\n      보드 위 길 중앙을 <b>0번부터 31번까지 순서대로 클릭</b><br>\r\n      <span class=\"warn\">0 = 출발, 31 = 도착</span>\r\n    </div>\r\n\r\n    <div class=\"btns\">\r\n      <button onclick=\"undoPoint()\">되돌리기</button>\r\n      <button class=\"danger\" onclick=\"clearPoints()\">전체삭제</button>\r\n      <button onclick=\"copyCoords()\">복사</button>\r\n      <button onclick=\"downloadCoords()\">txt 저장</button>\r\n    </div>\r\n\r\n    <textarea id=\"output\" spellcheck=\"false\"></textarea>\r\n  </div>\r\n</div>\r\n\r\n<script>\r\nconst DESIGN_W = 1600;\r\nconst DESIGN_H = 900;\r\nconst points = [];\r\n\r\nconst boardBox = document.getElementById('boardBox');\r\nconst output = document.getElementById('output');\r\n\r\nboardBox.addEventListener('click', function (e) {\r\n  if (points.length >= 32) return;\r\n\r\n  const rect = boardBox.getBoundingClientRect();\r\n  const relX = (e.clientX - rect.left) / rect.width;\r\n  const relY = (e.clientY - rect.top) / rect.height;\r\n\r\n  const x = Math.round(relX * DESIGN_W);\r\n  const y = Math.round(relY * DESIGN_H);\r\n\r\n  points.push({ x, y });\r\n  render();\r\n});\r\n\r\nfunction render() {\r\n  boardBox.querySelectorAll('.dot').forEach(el => el.remove());\r\n\r\n  points.forEach((p, i) => {\r\n    const dot = document.createElement('div');\r\n    dot.className = 'dot';\r\n    dot.textContent = i;\r\n    dot.style.left = (p.x / DESIGN_W * 100) + '%';\r\n    dot.style.top = (p.y / DESIGN_H * 100) + '%';\r\n    boardBox.appendChild(dot);\r\n  });\r\n\r\n  output.value =\r\n`const TILE_COORDS = [\r\n${points.map(p => `  { x: ${p.x}, y: ${p.y} }`).join(',\\n')}\r\n];`;\r\n}\r\n\r\nfunction undoPoint() {\r\n  points.pop();\r\n  render();\r\n}\r\n\r\nfunction clearPoints() {\r\n  points.length = 0;\r\n  render();\r\n}\r\n\r\nasync function copyCoords() {\r\n  await navigator.clipboard.writeText(output.value);\r\n  alert('좌표 복사 완료');\r\n}\r\n\r\nfunction downloadCoords() {\r\n  const blob = new Blob([output.value], { type: 'text/plain;charset=utf-8' });\r\n  const a = document.createElement('a');\r\n  a.href = URL.createObjectURL(blob);\r\n  a.download = 'tile-coords.txt';\r\n  a.click();\r\n  URL.revokeObjectURL(a.href);\r\n}\r\n\r\ndocument.getElementById('board').addEventListener('error', function () {\r\n  alert('board-main.webp 로딩 실패: assets/board/board-main.webp 위치 확인');\r\n});\r\n</script>\r\n</body>\r\n</html>"
        }
    ]
}