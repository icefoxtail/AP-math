            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"ko\">\r\n<head>\r\n<meta charset=\"UTF-8\" />\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n<title>Boardland Coordinate Picker v3.1</title>\r\n<style>\r\n  * { box-sizing: border-box; }\r\n\r\n  html,\r\n  body {\r\n    margin: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    overflow: hidden;\r\n    font-family: Arial, \"Noto Sans KR\", sans-serif;\r\n    background: #15110d;\r\n    color: #fff;\r\n  }\r\n\r\n  body {\r\n    display: grid;\r\n    grid-template-columns: 1fr 430px;\r\n  }\r\n\r\n  #stageWrap {\r\n    width: 100%;\r\n    height: 100%;\r\n    display: grid;\r\n    place-items: center;\r\n    overflow: hidden;\r\n    background: #1d140f;\r\n  }\r\n\r\n  #stage {\r\n    position: relative;\r\n    width: min(calc(100vw - 430px), calc(100vh * 16 / 9));\r\n    aspect-ratio: 16 / 9;\r\n    background: #000;\r\n    box-shadow: 0 0 0 2px rgba(255,255,255,0.25), 0 20px 60px rgba(0,0,0,0.55);\r\n    user-select: none;\r\n    cursor: crosshair;\r\n  }\r\n\r\n  #board {\r\n    position: absolute;\r\n    inset: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    object-fit: fill;\r\n    pointer-events: none;\r\n    display: block;\r\n  }\r\n\r\n  #pathLine {\r\n    position: absolute;\r\n    inset: 0;\r\n    pointer-events: none;\r\n    z-index: 8;\r\n  }\r\n\r\n  .point {\r\n    position: absolute;\r\n    width: 34px;\r\n    height: 34px;\r\n    transform: translate(-50%, -50%);\r\n    border-radius: 999px;\r\n    border: 3px solid #fff;\r\n    display: grid;\r\n    place-items: center;\r\n    font-size: 13px;\r\n    font-weight: 900;\r\n    color: #fff;\r\n    text-shadow: 0 2px 2px rgba(0,0,0,0.55);\r\n    pointer-events: none;\r\n    box-shadow: 0 4px 10px rgba(0,0,0,0.35);\r\n    z-index: 10;\r\n  }\r\n\r\n  .point.start { background: rgba(255, 100, 180, 0.95); }\r\n  .point.tile { background: rgba(255, 78, 78, 0.82); }\r\n  .point.card { background: rgba(131, 80, 255, 0.9); }\r\n  .point.gift { background: rgba(255, 190, 40, 0.95); color: #432000; text-shadow: none; }\r\n  .point.roulette { background: rgba(30, 180, 255, 0.95); }\r\n  .point.seat { background: rgba(80, 210, 110, 0.95); color: #062913; text-shadow: none; }\r\n\r\n  #side {\r\n    height: 100vh;\r\n    overflow: auto;\r\n    padding: 16px;\r\n    background: #24170f;\r\n    border-left: 1px solid rgba(255,255,255,0.18);\r\n  }\r\n\r\n  h1 {\r\n    margin: 0 0 10px;\r\n    font-size: 22px;\r\n  }\r\n\r\n  .guide {\r\n    margin: 0 0 14px;\r\n    padding: 12px;\r\n    border-radius: 12px;\r\n    background: rgba(255,255,255,0.08);\r\n    line-height: 1.5;\r\n    font-size: 13px;\r\n    color: #ffe9c7;\r\n  }\r\n\r\n  .setting {\r\n    display: grid;\r\n    grid-template-columns: 1fr 110px;\r\n    gap: 8px;\r\n    align-items: center;\r\n    margin-bottom: 10px;\r\n    padding: 10px;\r\n    border-radius: 12px;\r\n    background: rgba(255,255,255,0.08);\r\n  }\r\n\r\n  .setting label {\r\n    font-size: 14px;\r\n    font-weight: 900;\r\n    color: #ffe9c7;\r\n  }\r\n\r\n  .setting input {\r\n    height: 38px;\r\n    border: 0;\r\n    border-radius: 10px;\r\n    padding: 0 10px;\r\n    font-size: 17px;\r\n    font-weight: 900;\r\n    text-align: center;\r\n    background: #fff3cf;\r\n    color: #42250e;\r\n    outline: none;\r\n  }\r\n\r\n  .counter {\r\n    margin: 0 0 12px;\r\n    padding: 12px;\r\n    border-radius: 12px;\r\n    background: #fff3cf;\r\n    color: #42250e;\r\n    font-size: 19px;\r\n    font-weight: 900;\r\n    text-align: center;\r\n  }\r\n\r\n  .status {\r\n    margin: 0 0 12px;\r\n    padding: 10px 12px;\r\n    border-radius: 12px;\r\n    background: rgba(255,255,255,0.08);\r\n    font-size: 13px;\r\n    line-height: 1.45;\r\n    color: #eee;\r\n  }\r\n\r\n  .status.pass {\r\n    background: rgba(71, 255, 163, 0.15);\r\n    color: #adffd5;\r\n  }\r\n\r\n  .status.warn {\r\n    background: rgba(255, 210, 90, 0.16);\r\n    color: #ffe49c;\r\n  }\r\n\r\n  .buttons {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: 8px;\r\n    margin-bottom: 12px;\r\n  }\r\n\r\n  button {\r\n    min-height: 44px;\r\n    border: 0;\r\n    border-radius: 12px;\r\n    padding: 0 10px;\r\n    font-size: 14px;\r\n    font-weight: 900;\r\n    cursor: pointer;\r\n  }\r\n\r\n  #undoBtn { background: #ffd166; color: #402300; }\r\n  #resetBtn { background: #ff6b6b; color: #fff; }\r\n  #saveBtn { background: #93c5fd; color: #082f49; }\r\n  #loadBtn { background: #c4b5fd; color: #2e1065; }\r\n  #copyBtn { grid-column: 1 / -1; background: #6ee7b7; color: #073b2a; }\r\n\r\n  textarea {\r\n    width: 100%;\r\n    height: 470px;\r\n    resize: vertical;\r\n    border: 0;\r\n    border-radius: 12px;\r\n    padding: 12px;\r\n    background: #0e0b08;\r\n    color: #f8f8f2;\r\n    font-family: Consolas, Monaco, monospace;\r\n    font-size: 12px;\r\n    line-height: 1.45;\r\n    outline: none;\r\n  }\r\n\r\n  .list {\r\n    margin-top: 12px;\r\n    display: grid;\r\n    gap: 5px;\r\n    font-size: 12px;\r\n    color: #ddd;\r\n    padding-bottom: 30px;\r\n  }\r\n\r\n  .row {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    gap: 8px;\r\n    padding: 6px 8px;\r\n    border-radius: 8px;\r\n    background: rgba(255,255,255,0.06);\r\n  }\r\n\r\n  .name { color: #ffe9c7; }\r\n  .xy {\r\n    color: #8fffc1;\r\n    font-family: Consolas, Monaco, monospace;\r\n    white-space: nowrap;\r\n  }\r\n\r\n  .load-error {\r\n    position: absolute;\r\n    inset: 0;\r\n    display: none;\r\n    place-items: center;\r\n    padding: 30px;\r\n    background: #050505;\r\n    color: #ffdddd;\r\n    font-size: 18px;\r\n    font-weight: 900;\r\n    text-align: center;\r\n    line-height: 1.55;\r\n    z-index: 50;\r\n  }\r\n\r\n  .mini {\r\n    opacity: 0.78;\r\n    font-size: 12px;\r\n  }\r\n\r\n  @media (max-width: 980px) {\r\n    html,\r\n    body {\r\n      overflow: auto;\r\n    }\r\n\r\n    body {\r\n      grid-template-columns: 1fr;\r\n      grid-template-rows: auto 1fr;\r\n    }\r\n\r\n    #stageWrap {\r\n      height: auto;\r\n      padding: 8px;\r\n    }\r\n\r\n    #stage {\r\n      width: 100%;\r\n      max-width: 100vw;\r\n    }\r\n\r\n    #side {\r\n      height: auto;\r\n      border-left: 0;\r\n      border-top: 1px solid rgba(255,255,255,0.18);\r\n    }\r\n\r\n    textarea {\r\n      height: 360px;\r\n    }\r\n  }\r\n</style>\r\n</head>\r\n<body>\r\n  <main id=\"stageWrap\">\r\n    <div id=\"stage\">\r\n      <img id=\"board\" src=\"./assets/board/board-main.webp\" alt=\"board\" />\r\n      <svg id=\"pathLine\" viewBox=\"0 0 1600 900\" preserveAspectRatio=\"none\"></svg>\r\n      <div id=\"loadError\" class=\"load-error\">\r\n        보드 이미지를 불러오지 못했습니다.<br />\r\n        아래 파일 중 하나가 필요합니다.<br /><br />\r\n        assets/board/board-main.webp<br />\r\n        assets/board/board-main.png\r\n      </div>\r\n    </div>\r\n  </main>\r\n\r\n  <aside id=\"side\">\r\n    <h1>보드랜드 좌표 찍기 v3.1</h1>\r\n\r\n    <div class=\"guide\">\r\n      <b>먼저 실제 보드칸 총 개수를 입력하세요.</b><br>\r\n      기본값은 32칸입니다.<br><br>\r\n      클릭 순서:<br>\r\n      1~보드칸 수: 이동칸 전체<br>\r\n      그 다음: 카드더미 중심<br>\r\n      그 다음: 선물상자 중심<br>\r\n      그 다음: 룰렛 접시 중심<br>\r\n      마지막 4개: 말 시작 구멍\r\n    </div>\r\n\r\n    <div class=\"setting\">\r\n      <label for=\"tileCountInput\">보드 이동칸 총 개수</label>\r\n      <input id=\"tileCountInput\" type=\"number\" min=\"1\" max=\"80\" value=\"32\" />\r\n    </div>\r\n\r\n    <div class=\"counter\" id=\"counter\">다음: 1번 START 집</div>\r\n    <div class=\"status warn\" id=\"status\">0 / 36 입력됨</div>\r\n\r\n    <div class=\"buttons\">\r\n      <button id=\"undoBtn\" type=\"button\">되돌리기</button>\r\n      <button id=\"resetBtn\" type=\"button\">전체삭제</button>\r\n      <button id=\"saveBtn\" type=\"button\">임시저장</button>\r\n      <button id=\"loadBtn\" type=\"button\">불러오기</button>\r\n      <button id=\"copyBtn\" type=\"button\">좌표 복사</button>\r\n    </div>\r\n\r\n    <textarea id=\"output\" spellcheck=\"false\"></textarea>\r\n    <div class=\"list\" id=\"list\"></div>\r\n  </aside>\r\n\r\n<script>\r\n(function () {\r\n  'use strict';\r\n\r\n  const DESIGN_W = 1600;\r\n  const DESIGN_H = 900;\r\n  const STORAGE_KEY = 'boardland-coordinate-picker-v3-1';\r\n\r\n  const stage = document.getElementById('stage');\r\n  const board = document.getElementById('board');\r\n  const loadError = document.getElementById('loadError');\r\n  const pathLine = document.getElementById('pathLine');\r\n  const tileCountInput = document.getElementById('tileCountInput');\r\n  const counter = document.getElementById('counter');\r\n  const statusBox = document.getElementById('status');\r\n  const output = document.getElementById('output');\r\n  const list = document.getElementById('list');\r\n  const undoBtn = document.getElementById('undoBtn');\r\n  const resetBtn = document.getElementById('resetBtn');\r\n  const copyBtn = document.getElementById('copyBtn');\r\n  const saveBtn = document.getElementById('saveBtn');\r\n  const loadBtn = document.getElementById('loadBtn');\r\n\r\n  const points = [];\r\n\r\n  board.addEventListener('error', function () {\r\n    if (board.dataset.fallbackTried === '1') {\r\n      loadError.style.display = 'grid';\r\n      return;\r\n    }\r\n\r\n    board.dataset.fallbackTried = '1';\r\n    board.src = './assets/board/board-main.png';\r\n  });\r\n\r\n  board.addEventListener('load', function () {\r\n    loadError.style.display = 'none';\r\n  });\r\n\r\n  function getTileCount() {\r\n    const n = parseInt(tileCountInput.value, 10);\r\n    if (!Number.isFinite(n)) return 32;\r\n    return Math.max(1, Math.min(80, n));\r\n  }\r\n\r\n  function getMaxPoints() {\r\n    return getTileCount() + 7;\r\n  }\r\n\r\n  function getSpecialIndex(kind) {\r\n    const tileCount = getTileCount();\r\n    if (kind === 'card') return tileCount + 1;\r\n    if (kind === 'gift') return tileCount + 2;\r\n    if (kind === 'roulette') return tileCount + 3;\r\n    if (kind === 'seatStart') return tileCount + 4;\r\n    if (kind === 'seatEnd') return tileCount + 7;\r\n    return 0;\r\n  }\r\n\r\n  function getPointName(index) {\r\n    const tileCount = getTileCount();\r\n    const cardIndex = getSpecialIndex('card');\r\n    const giftIndex = getSpecialIndex('gift');\r\n    const rouletteIndex = getSpecialIndex('roulette');\r\n    const seatStart = getSpecialIndex('seatStart');\r\n    const seatEnd = getSpecialIndex('seatEnd');\r\n\r\n    if (index === 1) return 'START 집';\r\n    if (index >= 2 && index <= tileCount) return `${index}번 이동칸`;\r\n    if (index === cardIndex) return '카드더미 중심';\r\n    if (index === giftIndex) return '선물상자 중심';\r\n    if (index === rouletteIndex) return '룰렛 접시 중심';\r\n    if (index >= seatStart && index <= seatEnd) return `${index - seatStart + 1}번 말 시작 구멍`;\r\n    return `${index}번`;\r\n  }\r\n\r\n  function getPointClass(index) {\r\n    const tileCount = getTileCount();\r\n    const cardIndex = getSpecialIndex('card');\r\n    const giftIndex = getSpecialIndex('gift');\r\n    const rouletteIndex = getSpecialIndex('roulette');\r\n    const seatStart = getSpecialIndex('seatStart');\r\n    const seatEnd = getSpecialIndex('seatEnd');\r\n\r\n    if (index === 1) return 'start';\r\n    if (index >= 1 && index <= tileCount) return 'tile';\r\n    if (index === cardIndex) return 'card';\r\n    if (index === giftIndex) return 'gift';\r\n    if (index === rouletteIndex) return 'roulette';\r\n    if (index >= seatStart && index <= seatEnd) return 'seat';\r\n    return 'tile';\r\n  }\r\n\r\n  function renderPathLine() {\r\n    const tileCount = getTileCount();\r\n    const tilePoints = points.slice(0, tileCount);\r\n    pathLine.innerHTML = '';\r\n\r\n    if (tilePoints.length < 2) return;\r\n\r\n    const polyline = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');\r\n    polyline.setAttribute('points', tilePoints.map(p => `${p.x},${p.y}`).join(' '));\r\n    polyline.setAttribute('fill', 'none');\r\n    polyline.setAttribute('stroke', 'rgba(255, 255, 255, 0.72)');\r\n    polyline.setAttribute('stroke-width', '5');\r\n    polyline.setAttribute('stroke-linecap', 'round');\r\n    polyline.setAttribute('stroke-linejoin', 'round');\r\n    pathLine.appendChild(polyline);\r\n\r\n    if (tilePoints.length === tileCount) {\r\n      const closeLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');\r\n      closeLine.setAttribute('x1', String(tilePoints[tileCount - 1].x));\r\n      closeLine.setAttribute('y1', String(tilePoints[tileCount - 1].y));\r\n      closeLine.setAttribute('x2', String(tilePoints[0].x));\r\n      closeLine.setAttribute('y2', String(tilePoints[0].y));\r\n      closeLine.setAttribute('stroke', 'rgba(110, 231, 183, 0.75)');\r\n      closeLine.setAttribute('stroke-width', '4');\r\n      closeLine.setAttribute('stroke-dasharray', '12 10');\r\n      closeLine.setAttribute('stroke-linecap', 'round');\r\n      pathLine.appendChild(closeLine);\r\n    }\r\n  }\r\n\r\n  function renderPoints() {\r\n    stage.querySelectorAll('.point').forEach(el => el.remove());\r\n\r\n    points.forEach((p, i) => {\r\n      const idx = i + 1;\r\n      const dot = document.createElement('div');\r\n      dot.className = `point ${getPointClass(idx)}`;\r\n      dot.style.left = `${p.x / DESIGN_W * 100}%`;\r\n      dot.style.top = `${p.y / DESIGN_H * 100}%`;\r\n      dot.textContent = String(idx);\r\n      dot.title = `${idx}. ${getPointName(idx)} / x:${p.x}, y:${p.y}`;\r\n      stage.appendChild(dot);\r\n    });\r\n\r\n    renderPathLine();\r\n  }\r\n\r\n  function makePointLine(p) {\r\n    return `  { x: ${p.x}, y: ${p.y} }`;\r\n  }\r\n\r\n  function buildOutput() {\r\n    const tileCount = getTileCount();\r\n    const tilePoints = points.slice(0, tileCount);\r\n    const card = points[tileCount] || { x: 0, y: 0 };\r\n    const gift = points[tileCount + 1] || { x: 0, y: 0 };\r\n    const roulette = points[tileCount + 2] || { x: 0, y: 0 };\r\n    const seats = points.slice(tileCount + 3, tileCount + 7);\r\n\r\n    const tileText = tilePoints.map(makePointLine).join(',\\n');\r\n    const seatText = seats.map(makePointLine).join(',\\n');\r\n    const start = tilePoints[0] || { x: 0, y: 0 };\r\n\r\n    return `const START_HOME_COORD = { x: ${start.x}, y: ${start.y} };\r\n\r\nconst TILE_COORDS = [\r\n${tileText}\r\n];\r\n\r\nconst CARD_COORD = { x: ${card.x}, y: ${card.y} };\r\nconst GIFT_COORD = { x: ${gift.x}, y: ${gift.y} };\r\nconst ROULETTE_COORD = { x: ${roulette.x}, y: ${roulette.y} };\r\n\r\nconst PLAYER_SEAT_COORDS = [\r\n${seatText}\r\n];`;\r\n  }\r\n\r\n  function renderList() {\r\n    list.innerHTML = '';\r\n\r\n    points.forEach((p, i) => {\r\n      const idx = i + 1;\r\n      const row = document.createElement('div');\r\n      row.className = 'row';\r\n      row.innerHTML = `\r\n        <span class=\"name\">${idx}. ${getPointName(idx)}</span>\r\n        <span class=\"xy\">x:${p.x}, y:${p.y}</span>\r\n      `;\r\n      list.appendChild(row);\r\n    });\r\n  }\r\n\r\n  function validate() {\r\n    const tileCount = getTileCount();\r\n    const maxPoints = getMaxPoints();\r\n    const count = points.length;\r\n    const tileDone = Math.min(count, tileCount);\r\n    const seatDone = Math.max(0, Math.min(count - tileCount - 3, 4));\r\n\r\n    if (count === maxPoints) {\r\n      statusBox.className = 'status pass';\r\n      statusBox.innerHTML = `PASS: ${count} / ${maxPoints} 완료<br><span class=\"mini\">TILE_COORDS ${tileCount}개, 카드/선물/룰렛, 말 4개 입력 완료</span>`;\r\n      return;\r\n    }\r\n\r\n    statusBox.className = 'status warn';\r\n    statusBox.innerHTML = `${count} / ${maxPoints} 입력됨<br><span class=\"mini\">보드칸 ${tileDone}/${tileCount} · 말 ${seatDone}/4</span>`;\r\n  }\r\n\r\n  function update() {\r\n    renderPoints();\r\n    renderList();\r\n    output.value = buildOutput();\r\n    validate();\r\n\r\n    const next = points.length + 1;\r\n    const maxPoints = getMaxPoints();\r\n\r\n    if (next <= maxPoints) {\r\n      counter.textContent = `다음: ${next}번 ${getPointName(next)}`;\r\n    } else {\r\n      counter.textContent = '좌표 완료';\r\n    }\r\n  }\r\n\r\n  function addPoint(clientX, clientY) {\r\n    if (points.length >= getMaxPoints()) return;\r\n\r\n    const rect = stage.getBoundingClientRect();\r\n    const px = (clientX - rect.left) / rect.width;\r\n    const py = (clientY - rect.top) / rect.height;\r\n\r\n    const x = Math.round(px * DESIGN_W);\r\n    const y = Math.round(py * DESIGN_H);\r\n\r\n    points.push({ x, y });\r\n    update();\r\n  }\r\n\r\n  function savePoints() {\r\n    localStorage.setItem(STORAGE_KEY, JSON.stringify({\r\n      tileCount: getTileCount(),\r\n      points\r\n    }));\r\n\r\n    saveBtn.textContent = '저장 완료';\r\n    setTimeout(() => {\r\n      saveBtn.textContent = '임시저장';\r\n    }, 900);\r\n  }\r\n\r\n  function loadPoints() {\r\n    try {\r\n      const raw = localStorage.getItem(STORAGE_KEY);\r\n      if (!raw) return;\r\n\r\n      const parsed = JSON.parse(raw);\r\n      const loadedPoints = Array.isArray(parsed) ? parsed : parsed.points;\r\n      const loadedTileCount = Array.isArray(parsed) ? null : parsed.tileCount;\r\n\r\n      if (loadedTileCount) {\r\n        tileCountInput.value = String(loadedTileCount);\r\n      }\r\n\r\n      if (!Array.isArray(loadedPoints)) return;\r\n\r\n      points.length = 0;\r\n      loadedPoints.slice(0, getMaxPoints()).forEach(p => {\r\n        if (!p || typeof p.x !== 'number' || typeof p.y !== 'number') return;\r\n        points.push({ x: Math.round(p.x), y: Math.round(p.y) });\r\n      });\r\n\r\n      update();\r\n\r\n      loadBtn.textContent = '불러옴';\r\n      setTimeout(() => {\r\n        loadBtn.textContent = '불러오기';\r\n      }, 900);\r\n    } catch (error) {}\r\n  }\r\n\r\n  stage.addEventListener('click', function (event) {\r\n    if (event.target === loadError) return;\r\n    addPoint(event.clientX, event.clientY);\r\n  });\r\n\r\n  tileCountInput.addEventListener('change', function () {\r\n    const maxPoints = getMaxPoints();\r\n    if (points.length > maxPoints) {\r\n      points.length = maxPoints;\r\n    }\r\n    update();\r\n  });\r\n\r\n  undoBtn.addEventListener('click', function () {\r\n    points.pop();\r\n    update();\r\n  });\r\n\r\n  resetBtn.addEventListener('click', function () {\r\n    if (!confirm('좌표를 전부 삭제할까요?')) return;\r\n    points.length = 0;\r\n    update();\r\n  });\r\n\r\n  saveBtn.addEventListener('click', savePoints);\r\n  loadBtn.addEventListener('click', loadPoints);\r\n\r\n  copyBtn.addEventListener('click', async function () {\r\n    output.select();\r\n    output.setSelectionRange(0, output.value.length);\r\n\r\n    try {\r\n      await navigator.clipboard.writeText(output.value);\r\n      copyBtn.textContent = '복사 완료';\r\n      setTimeout(() => {\r\n        copyBtn.textContent = '좌표 복사';\r\n      }, 900);\r\n    } catch (error) {\r\n      document.execCommand('copy');\r\n      copyBtn.textContent = '복사 완료';\r\n      setTimeout(() => {\r\n        copyBtn.textContent = '좌표 복사';\r\n      }, 900);\r\n    }\r\n  });\r\n\r\n  window.addEventListener('keydown', function (event) {\r\n    const key = event.key.toLowerCase();\r\n\r\n    if ((event.ctrlKey || event.metaKey) && key === 'z') {\r\n      event.preventDefault();\r\n      points.pop();\r\n      update();\r\n    }\r\n\r\n    if ((event.ctrlKey || event.metaKey) && key === 's') {\r\n      event.preventDefault();\r\n      savePoints();\r\n    }\r\n  });\r\n\r\n  update();\r\n})();\r\n</script>\r\n</body>\r\n</html>"
        }
