            "content": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>JS아카이브 엔진</title>\n    <script>\n        window.MathJax = {\n            tex: {\n                inlineMath: [['$', '$']],\n                displayMath: [['$$', '$$']],\n                packages: {'[+]': ['ams', 'boldsymbol']}\n            },\n            options: { enableMenu: false },\n            startup: { typeset: false }\n        };\n    </script>\n    <script id=\"MathJax-script\" async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js\"></script>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&display=swap');\n        @page { size: A4; margin: 0; }\n\n        body {\n            margin: 0;\n            font-family: 'Nanum Myeongjo', serif;\n            font-size: 9.5pt;\n            background: #f1f5f9;\n            padding-top: 54px;\n            color: #000;\n        }\n\n        #mode-ctrl {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 56px;\n            background: #0f172a;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 0 24px;\n            z-index: 1000;\n            box-sizing: border-box;\n            border-bottom: 1px solid rgba(255,255,255,0.08);\n            gap: 16px;\n        }\n\n        #ctrl-title {\n            font-size: 14px;\n            font-weight: 800;\n            color: white;\n            white-space: nowrap;\n            letter-spacing: -0.3px;\n            flex-shrink: 0;\n        }\n\n        .mode-tabs {\n            display: flex;\n            gap: 4px;\n            background: rgba(255,255,255,0.07);\n            padding: 4px;\n            border-radius: 10px;\n            flex-shrink: 0;\n        }\n\n        .mode-tab {\n            padding: 6px 16px;\n            border-radius: 7px;\n            font-size: 12px;\n            font-weight: 700;\n            cursor: pointer;\n            border: none;\n            background: transparent;\n            color: rgba(255,255,255,0.5);\n            transition: 0.18s;\n            font-family: inherit;\n            letter-spacing: -0.2px;\n        }\n\n        .mode-tab:hover {\n            color: white;\n            background: rgba(255,255,255,0.1);\n        }\n\n        .mode-tab.active {\n            background: white;\n            color: #0f172a;\n            box-shadow: 0 1px 4px rgba(0,0,0,0.25);\n        }\n\n        .ctrl-right {\n            display: flex;\n            gap: 8px;\n            flex-shrink: 0;\n        }\n\n        .print-btn {\n            padding: 7px 16px;\n            border: none;\n            border-radius: 7px;\n            font-family: inherit;\n            font-weight: 700;\n            font-size: 12px;\n            cursor: pointer;\n            transition: 0.15s;\n        }\n\n        .print-btn.primary {\n            background: #378ADD;\n            color: white;\n        }\n\n        .print-btn.primary:hover {\n            background: #2e73c4;\n        }\n\n        .print-btn.ghost {\n            background: rgba(255,255,255,0.1);\n            color: rgba(255,255,255,0.8);\n        }\n\n        .print-btn.ghost:hover {\n            background: rgba(255,255,255,0.18);\n            color: white;\n        }\n\n        #print-area {\n            display: none;\n            flex-direction: column;\n            align-items: center;\n            gap: 20px;\n            padding: 20px 0;\n        }\n\n        .page {\n            width: 210mm;\n            height: 297mm;\n            background: white;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n            padding: 15mm;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            overflow: hidden;\n        }\n\n        @media print {\n            @page {\n                size: A4;\n                margin: 0;\n            }\n\n            body {\n                padding-top: 0;\n                margin: 0;\n                background: white;\n            }\n\n            #mode-ctrl {\n                display: none !important;\n            }\n\n            #print-area {\n                display: flex !important;\n                gap: 0;\n                padding: 0;\n            }\n\n            .page {\n                box-shadow: none;\n                page-break-after: always;\n            }\n\n            #pdf-container {\n                display: block !important;\n                position: fixed;\n                inset: 0;\n                width: 100vw;\n                height: 100vh;\n                background: white;\n                z-index: 9999;\n                margin: 0;\n                padding: 0;\n            }\n\n            #pdf-viewer {\n                width: 100%;\n                height: 100%;\n                border: none;\n            }\n\n            body:not(.mode-pdf) #pdf-container {\n                display: none !important;\n            }\n\n            body.mode-pdf #print-area {\n                display: none !important;\n            }\n        }\n\n        .page-header {\n            display: flex;\n            justify-content: space-between;\n            border-bottom: 2px solid #000;\n            padding-bottom: 5px;\n            margin-bottom: 12px;\n            font-weight: bold;\n            flex-shrink: 0;\n        }\n\n        #pdf-container {\n            display: none;\n            width: 100%;\n            height: calc(100vh - 54px);\n            background: #525659;\n            overflow: hidden;\n        }\n\n        #pdf-viewer {\n            width: 100%;\n            height: 100%;\n            border: none;\n            background: white;\n        }\n\n        .grid-container {\n            flex: 1;\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            position: relative;\n            overflow: hidden;\n            min-height: 0;\n        }\n\n        .grid-container::after {\n            content: '';\n            position: absolute;\n            left: 50%;\n            top: 0;\n            bottom: 0;\n            width: 1px;\n            background: #000;\n        }\n\n        .grid-col {\n            display: flex;\n            flex-direction: column;\n            padding: 0 12px;\n            overflow: hidden;\n            min-height: 0;\n        }\n\n        .q-box {\n            flex: 1 1 0;\n            min-height: 0;\n            padding: 10px 0;\n            border-bottom: 0.5px solid #ccc;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            word-break: keep-all;\n            overflow-wrap: anywhere;\n            line-height: 1.58;\n            font-size: 9.5pt;\n        }\n\n        .q-box:last-child {\n            border-bottom: none;\n        }\n\n        .q-num {\n            font-weight: bold;\n            font-size: 11pt;\n            margin-bottom: 6px;\n            flex-shrink: 0;\n        }\n\n        .q-content {\n            min-height: 0;\n        }\n\n        .box {\n            border: 1px solid #ccc;\n            border-radius: 4px;\n            padding: 8px 10px;\n            margin: 6px 0;\n            background: #f9f9f9;\n            font-size: 9pt;\n            line-height: 1.5;\n            overflow-x: auto;\n        }\n\n        .answer-box {\n            flex: 1;\n            border: 1px dashed #bbb;\n            margin-top: 8px;\n            background: #fafafa;\n        }\n\n        .choices {\n            margin-top: 7px;\n            line-height: 1.72;\n        }\n\n        .q-box.fit-tight {\n            font-size: 9.0pt;\n            line-height: 1.40;\n        }\n\n        .q-box.fit-tight .q-num {\n            font-size: 10.5pt;\n            margin-bottom: 4px;\n        }\n\n        .q-box.fit-tight .choices {\n            margin-top: 5px;\n            line-height: 1.54;\n        }\n\n        .q-box.fit-tighter {\n            font-size: 8.6pt;\n            line-height: 1.31;\n        }\n\n        .q-box.fit-tighter .q-num {\n            font-size: 10pt;\n            margin-bottom: 3px;\n        }\n\n        .q-box.fit-tighter .choices {\n            margin-top: 4px;\n            line-height: 1.42;\n        }\n\n        .q-box.fit-micro {\n            font-size: 8.1pt;\n            line-height: 1.23;\n        }\n\n        .q-box.fit-micro .q-num {\n            font-size: 9.5pt;\n            margin-bottom: 2px;\n        }\n\n        .q-box.fit-micro .choices {\n            margin-top: 2px;\n            line-height: 1.30;\n        }\n\n        .sol-box {\n            padding: 0;\n            border-bottom: none;\n            width: 100%;\n            margin-bottom: 0;\n        }\n\n        .sol-head {\n            padding: 8px 0 4px 0;\n            width: 100%;\n            font-size: 9pt;\n            line-height: 1.5;\n        }\n\n        .sol-head .q-num {\n            margin-bottom: 0;\n        }\n\n        .sol-frag {\n            width: 100%;\n            margin-bottom: 4px;\n        }\n\n        .sol-step {\n            padding-left: 8px;\n            border-left: 2px solid #e2e8f0;\n            margin-bottom: 4px;\n            font-size: 9pt;\n            line-height: 1.5;\n            word-break: keep-all;\n            overflow-wrap: anywhere;\n            break-inside: avoid;\n            page-break-inside: avoid;\n        }\n\n        .sol-divider {\n            border-bottom: 0.5px solid #eee;\n            margin: 8px 0 36px 0;\n        }\n\n        .ans-grid {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            column-gap: 24px;\n            row-gap: 2px;\n            margin-top: 5px;\n        }\n\n        .ans-cell {\n            padding: 4px 8px;\n            display: flex;\n            align-items: flex-start;\n            gap: 12px;\n            border-bottom: 0.1px solid #f0f0f0;\n        }\n    </style>\n</head>\n<body>\n\n    <div id=\"mode-ctrl\">\n        <span id=\"ctrl-title\">JS아카이브</span>\n        <div class=\"mode-tabs\" id=\"modeTabs\">\n            <button class=\"mode-tab\" data-mode=\"exam\" onclick=\"switchMode('exam')\">시험지</button>\n            <button class=\"mode-tab\" data-mode=\"sol\" onclick=\"switchMode('sol')\">해설지</button>\n            <button class=\"mode-tab\" data-mode=\"ans\" onclick=\"switchMode('ans')\">정답표</button>\n        </div>\n        <div class=\"ctrl-right\">\n            <button class=\"print-btn ghost\" id=\"pdf-open-btn\" style=\"display:none;\">↗ PDF 새 탭</button>\n            <button class=\"print-btn primary\" onclick=\"window.print()\">🖨 인쇄</button>\n        </div>\n    </div>\n\n    <div id=\"pdf-container\">\n        <iframe id=\"pdf-viewer\" src=\"\"></iframe>\n    </div>\n\n    <div id=\"print-area\"></div>\n    <div id=\"staging\" style=\"position:absolute;top:-9999px;left:0;visibility:hidden;width:85mm;\"></div>\n\n<script>\nconst AppState = { title: 'JS아카이브', data: [], mode: 'exam', qpp: 4 };\nlet pageCount = 0;\n\nfunction esc(str) {\n    if (!str) return '';\n    const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;', \"'\": '&#039;' };\n    return String(str).replace(/[&<>\"']/g, m => map[m]);\n}\n\nfunction injectHeaderAndStyles() {\n    if (!document.getElementById('engine-custom-style')) {\n        const style = document.createElement('style');\n        style.id = 'engine-custom-style';\n        style.innerHTML = `\n            .print-header { margin-bottom:20px; padding-bottom:10px; border-bottom:2px solid #000; font-family: sans-serif; }\n            .print-header-title { font-size:24px; font-weight:800; text-align:center; word-break: break-all; }\n            .print-header-meta { display:flex; justify-content:space-between; margin-top:10px; font-size:14px; font-weight:600; }\n            .ans-sheet-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 10px; padding: 10px 0; }\n            .ans-unit { display: flex; border: 1px solid #cbd5e1; border-radius: 4px; overflow: hidden; font-size: 14px; background: #fff; height: 32px; align-items: center; }\n            .ans-idx { background: #f8fafc; width: 30px; height: 100%; display: flex; align-items: center; justify-content: center; font-weight: 800; border-right: 1px solid #cbd5e1; color: #475569; flex-shrink: 0; }\n            .ans-text { flex: 1; text-align: center; font-weight: 600; color: #1e293b; padding: 0 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n            .sol-missing-msg { color: #94a3b8; font-size: 0.9em; font-style: italic; margin-top: 5px; }\n        `;\n        document.head.appendChild(style);\n    }\n\n    const target = document.getElementById('print-area');\n    if (!target || target.querySelector('.print-header')) return;\n\n    const modeLabel = AppState.mode === 'exam' ? '시험지' : AppState.mode === 'sol' ? '해설지' : '정답표';\n    const qppLabel = AppState.mode === 'exam' ? AppState.qpp + '단 구성' : '';\n\n    const headerHtml = `\n        <div class=\"print-header\">\n            <div class=\"print-header-title\">${esc(AppState.title)}</div>\n            <div class=\"print-header-meta\">\n                <span>출력 모드: ${modeLabel}</span>\n                <span>${qppLabel}</span>\n            </div>\n        </div>\n    `;\n    target.insertAdjacentHTML('afterbegin', headerHtml);\n}\n\nfunction renderAnswerSheetOnly() {\n    const target = document.getElementById('print-area');\n    if (!target) return;\n    target.innerHTML = '';\n\n    const grid = document.createElement('div');\n    grid.className = 'ans-sheet-grid';\n    AppState.data.forEach((item, idx) => {\n        const unit = document.createElement('div');\n        unit.className = 'ans-unit';\n        unit.innerHTML = `\n            <div class=\"ans-idx\">${idx + 1}</div>\n            <div class=\"ans-text\">${esc(item.answer) || ''}</div>\n        `;\n        grid.appendChild(unit);\n    });\n    target.appendChild(grid);\n}\n\n\nasync function loadData(dataUrl) {\n    if (dataUrl === 'mixed') {\n        let bank = [];\n        try {\n            const raw = sessionStorage.getItem('mixedQuestions') || localStorage.getItem('mixedQuestions');\n            if (!raw) return [];\n            const tasks = JSON.parse(raw);\n            if (Array.isArray(tasks)) {\n                const seenSourceRefs = new Set();\n                for (const task of tasks) {\n                    if (!task.sourceRef || seenSourceRefs.has(task.sourceRef)) continue;\n                    seenSourceRefs.add(task.sourceRef);\n\n                    window.mainDB = { exams: [] };\n                    window.questionBank = [];\n                    try {\n                        await new Promise((resolve) => {\n                            const script = document.createElement('script');\n                            script.src = encodeURI(decodeURI(task.sourceRef));\n                            script.onload = () => { resolve(); if (script.parentNode) script.parentNode.removeChild(script); };\n                            script.onerror = () => {\n                                if (script.parentNode) script.parentNode.removeChild(script);\n                                console.warn(`Resource skip: ${task.sourceRef}`);\n                                resolve();\n                            };\n                            document.head.appendChild(script);\n                        });\n                        const loaded = (Array.isArray(window.questionBank) && window.questionBank.length > 0)\n                                       ? window.questionBank\n                                       : (window.mainDB && Array.isArray(window.mainDB.exams) ? window.mainDB.exams : []);\n                        bank = [...bank, ...loaded];\n                    } catch (e) { }\n                }\n            }\n        } catch (e) { console.error('Mixed data parse error:', e); }\n        window.mainDB = { exams: [] };\n        window.questionBank = [];\n        return bank;\n    }\n\n    window.mainDB = { exams: [] };\n    window.questionBank = [];\n    try {\n        await new Promise((resolve, reject) => {\n            const script = document.createElement('script');\n            script.src = encodeURI(decodeURI(dataUrl));\n            script.onload = () => { resolve(); if (script.parentNode) script.parentNode.removeChild(script); };\n            script.onerror = (e) => { if (script.parentNode) script.parentNode.removeChild(script); reject(e); };\n            document.head.appendChild(script);\n        });\n        return (Array.isArray(window.questionBank) && window.questionBank.length > 0)\n               ? window.questionBank\n               : (window.mainDB && Array.isArray(window.mainDB.exams) ? window.mainDB.exams : []);\n    } catch (e) { console.error('Single load error:', e); return []; }\n}\n\nasync function init() {\n    const params = new URLSearchParams(window.location.search);\n    const dataUrl = params.get('data');\n    const fileUrl = params.get('file');\n    AppState.data_url = dataUrl;\n    AppState.mode = params.get('mode') || 'exam';\n\n    if (dataUrl === 'mixed') {\n        try {\n            const rawMeta = sessionStorage.getItem('mixedMeta') || localStorage.getItem('mixedMeta');\n            if (rawMeta) {\n                const mixedMeta = JSON.parse(rawMeta);\n                if (mixedMeta.title) AppState.title = mixedMeta.title;\n                if (mixedMeta.qpp) AppState.qpp = parseInt(mixedMeta.qpp) || AppState.qpp;\n            }\n        } catch (e) { console.error(\"MixedMeta load failed:\", e); }\n    }\n\n    if (params.has('title')) AppState.title = params.get('title');\n    const rawQpp = parseInt(params.get('qpp') || (dataUrl === 'mixed' ? AppState.qpp : null) || AppState.qpp);\n    AppState.qpp = Math.max(1, Math.min(8, isNaN(rawQpp) ? 2 : rawQpp));\n\n    const pdfContainer = document.getElementById('pdf-container');\n    if (pdfContainer) pdfContainer.style.display = 'none';\n\n    const printArea = document.getElementById('print-area');\n    if (printArea) printArea.style.display = 'flex';\n\n    const titleEl = document.getElementById('ctrl-title');\n    if (titleEl) titleEl.innerText = AppState.title;\n    updateTabs(AppState.mode);\n\n    if (AppState.mode === 'pdf' || fileUrl) {\n        if (printArea) {\n            printArea.innerHTML = '<div style=\"flex:1; padding:150px 0; text-align:center; color:#d32f2f; font-size:1.1em; background:#fff; font-weight:bold;\">PDF 출력 기능은 현재 비활성화되어 있습니다.<br><span style=\"color:#666; font-weight:normal; font-size:0.9em; margin-top:10px; display:block;\">JS 문항 기반의 시험지/해설지/정답표 출력을 이용해 주세요.</span></div>';\n        }\n        return;\n    }\n\n    if (dataUrl) {\n        const rawData = await loadData(dataUrl);\n\n        if (AppState.mode === 'sol') {\n            AppState.data = rawData.map(item => ({\n                ...item,\n                answer: (item.answer !== undefined && item.answer !== null) ? String(item.answer) : '',\n                solution: item.solution || '<div class=\"sol-missing-msg\">해설이 제공되지 않는 문항입니다.</div>'\n            }));\n        } else if (AppState.mode === 'exam') {\n            AppState.data = rawData.map(item => ({\n                ...item,\n                content: item.content || '(문항 내용 없음)',\n                choices: Array.isArray(item.choices) ? item.choices : []\n            }));\n        } else {\n            AppState.data = rawData;\n        }\n\n        if (dataUrl === 'mixed' && AppState.data.length === 0) {\n            if (printArea) {\n                printArea.innerHTML = '<div style=\"flex:1; padding:150px 0; text-align:center; color:#999; font-size:1.1em; background:#fff;\">선택된 문항이 없습니다. 믹서에서 문항을 추가한 후 다시 시도해 주세요.</div>';\n            }\n            return;\n        }\n\n        if (AppState.mode === 'ans') {\n            renderAnswerSheetOnly();\n            injectHeaderAndStyles();\n        } else {\n            await renderEngine();\n            if (!document.querySelector('#print-area .print-header')) {\n                injectHeaderAndStyles();\n            }\n        }\n    }\n}\n\nfunction updateTabs(mode) {\n    document.querySelectorAll('.mode-tab').forEach(btn => {\n        btn.classList.toggle('active', btn.dataset.mode === mode);\n    });\n}\n\nfunction switchMode(mode) {\n    if (mode === AppState.mode) return;\n    const url = new URL(window.location.href);\n    url.searchParams.set('mode', mode);\n    url.searchParams.set('qpp', AppState.qpp);\n    window.location.href = url.toString();\n}\n\nasync function renderEngine() {\n    const area = document.getElementById('print-area');\n    area.innerHTML = '';\n    pageCount = 0;\n\n    if (AppState.mode === 'ans') {\n        renderAnsGrid(area, AppState.data);\n    } else if (AppState.mode === 'sol') {\n        await renderSol(area, AppState.data);\n    } else {\n        await renderExam(area, AppState.data);\n    }\n}\n\nasync function renderExam(area, bank) {\n    const perCol = Math.ceil(AppState.qpp / 2);\n    const staging = document.getElementById('staging');\n    staging.style.width = '85mm';\n    staging.innerHTML = '';\n\n    const boxes = bank.map((q, i) => {\n        const el = document.createElement('div');\n        el.className = 'q-box';\n        el.innerHTML = buildExamBox(q, i);\n        staging.appendChild(el);\n        return el;\n    });\n\n    if (window.MathJax?.typesetPromise) await MathJax.typesetPromise([staging]);\n    await raf();\n\n    for (let start = 0; start < boxes.length; start += AppState.qpp) {\n        const chunk = boxes.slice(start, start + AppState.qpp);\n        const page = makePage(area, 'exam');\n\n        const leftItems = chunk.slice(0, perCol).map(el => el.cloneNode(true));\n        const rightItems = chunk.slice(perCol).map(el => el.cloneNode(true));\n\n        leftItems.forEach(el => page.cols[0].appendChild(el));\n        rightItems.forEach(el => page.cols[1].appendChild(el));\n\n        if (window.MathJax?.typesetPromise) {\n            await MathJax.typesetPromise([page.cols[0], page.cols[1]]);\n        }\n        await raf();\n\n        fitExamColumn(page.cols[0]);\n        fitExamColumn(page.cols[1]);\n\n        if (window.MathJax?.typesetPromise) {\n            await MathJax.typesetPromise([page.cols[0], page.cols[1]]);\n        }\n        await raf();\n    }\n}\n\nfunction extractChoice(c) {\n    if (c === null || c === undefined) return '';\n    if (typeof c === 'object') {\n        return c.text || c.content || c.value || c.answer || Object.values(c)[0] || '';\n    }\n    return String(c);\n}\n\nfunction buildExamBox(q, i) {\n    const circled = ['①','②','③','④','⑤'];\n    const isMultipleChoice =\n        Array.isArray(q.choices) &&\n        q.choices.length > 0 &&\n        q.choices[0] !== \"주관식\" &&\n        q.choices.some(c => extractChoice(c).trim() !== \"\");\n\n    const choicesHTML = isMultipleChoice\n        ? `<div class=\"choices\">${q.choices.map((c, ci) =>\n              `<div>${circled[ci] || (ci + 1) + ')'} ${wrapLatex(extractChoice(c))}</div>`).join('')}</div>`\n        : `<div class=\"answer-box\"></div>`;\n\n    return `\n        <div class=\"q-num\">${i + 1}.</div>\n        <div class=\"q-content\">${wrapLatex(q.content || q.question || '')}</div>\n        ${choicesHTML}\n    `;\n}\n\nfunction fitExamColumn(col) {\n    const boxes = [...col.querySelectorAll('.q-box')];\n    boxes.forEach(box => fitQuestionBox(box));\n}\n\nfunction fitQuestionBox(box) {\n    const fitClasses = ['', 'fit-tight', 'fit-tighter', 'fit-micro'];\n\n    for (const cls of fitClasses) {\n        box.classList.remove('fit-tight', 'fit-tighter', 'fit-micro');\n        if (cls) box.classList.add(cls);\n\n        if (box.scrollHeight <= box.clientHeight + 1) {\n            return;\n        }\n    }\n\n    const choices = box.querySelector('.choices');\n    if (choices) {\n        choices.style.lineHeight = '1.2';\n        choices.style.marginTop = '1px';\n    }\n\n    const qnum = box.querySelector('.q-num');\n    if (qnum) {\n        qnum.style.marginBottom = '1px';\n    }\n}\n\nfunction buildSolHeader(q, i) {\n    return `\n        <div class=\"sol-head\">\n            <div class=\"q-num\">${i + 1}.\n                <span style=\"font-size:9pt;font-weight:normal;\">\n                    ${wrapLatex(q.content || q.question || '')}\n                </span>\n            </div>\n        </div>\n    `;\n}\n\nfunction buildSolFragments(q) {\n    if (q.solution_steps?.length) {\n        return q.solution_steps.map((s, si) => `\n            <div class=\"sol-frag\">\n                <div class=\"sol-step\"><b>[${si + 1}단계]</b> ${wrapLatexPreserveBlocks(stripCite(s))}</div>\n            </div>\n        `);\n    }\n\n    if (q.solution) {\n        const raw = stripCite(q.solution);\n\n        const hasStructuredMath =\n            /\\\\begin\\{(array|aligned|matrix|pmatrix|bmatrix|vmatrix|Vmatrix|cases)\\}/.test(raw) ||\n            /\\\\multicolumn|\\\\cline|\\\\hline/.test(raw);\n\n        if (hasStructuredMath) {\n            return [\n                `<div class=\"sol-frag\"><div class=\"sol-step\">${wrapLatexPreserveBlocks(raw)}</div></div>`\n            ];\n        }\n\n        const lines = raw\n            .split(/\\n+/)\n            .map(v => v.trim())\n            .filter(Boolean);\n\n        return lines.map(line => `\n            <div class=\"sol-frag\">\n                <div class=\"sol-step\">${wrapLatexPreserveBlocks(line)}</div>\n            </div>\n        `);\n    }\n\n    return [\n        `<div class=\"sol-frag\"><div class=\"sol-step\" style=\"color:#94a3b8;font-size:8pt;\">해설 없음</div></div>`\n    ];\n}\n\nasync function renderSol(area, bank) {\n    let p = makePage(area, 'sol');\n    let colIdx = 0;\n\n    async function ensureFitOrAdvance(targetCol, node) {\n        targetCol.appendChild(node);\n\n        if (window.MathJax?.typesetPromise) {\n            await MathJax.typesetPromise([targetCol]);\n        }\n        await raf();\n\n        const overflowed = targetCol.scrollHeight > targetCol.clientHeight + 1;\n\n        if (!overflowed) return true;\n\n        node.remove();\n\n        if (colIdx === 0) {\n            colIdx = 1;\n        } else {\n            p = makePage(area, 'sol');\n            colIdx = 0;\n        }\n        return false;\n    }\n\n    for (let i = 0; i < bank.length; i++) {\n        const q = bank[i];\n\n        const headWrap = document.createElement('div');\n        headWrap.innerHTML = buildSolHeader(q, i).trim();\n        const headEl = headWrap.firstElementChild;\n\n        let placedHeader = false;\n        while (!placedHeader) {\n            const targetCol = p.cols[colIdx];\n            placedHeader = await ensureFitOrAdvance(targetCol, headEl.cloneNode(true));\n        }\n\n        const fragments = buildSolFragments(q);\n\n        for (const fragHTML of fragments) {\n            const fragWrap = document.createElement('div');\n            fragWrap.innerHTML = fragHTML.trim();\n            const fragEl = fragWrap.firstElementChild;\n\n            let placedFrag = false;\n            while (!placedFrag) {\n                const targetCol = p.cols[colIdx];\n                placedFrag = await ensureFitOrAdvance(targetCol, fragEl.cloneNode(true));\n            }\n        }\n\n        const divider = document.createElement('div');\n        divider.className = 'sol-divider';\n\n        let placedDivider = false;\n        while (!placedDivider) {\n            const targetCol = p.cols[colIdx];\n            placedDivider = await ensureFitOrAdvance(targetCol, divider.cloneNode(true));\n        }\n    }\n}\n\nfunction renderAnsGrid(area, bank) {\n    const p = makePage(area, 'ans');\n    const grid = document.createElement('div');\n    grid.className = 'ans-grid';\n\n    const splitIndex = Math.ceil(bank.length / 2);\n    const orderedItems = [];\n\n    for (let i = 0; i < splitIndex; i++) {\n        orderedItems.push({ q: bank[i], qNum: i + 1 });\n        if (bank[splitIndex + i]) {\n            orderedItems.push({ q: bank[splitIndex + i], qNum: splitIndex + i + 1 });\n        }\n    }\n\n    orderedItems.forEach(({ q, qNum }) => {\n        const cell = document.createElement('div');\n        cell.className = 'ans-cell';\n        const rawAns = String(q.answer ?? '–');\n        const displayAns = (rawAns.includes('sqrt') || rawAns.includes('/') || rawAns.includes('^'))\n            ? wrapLatex(rawAns)\n            : rawAns;\n\n        cell.innerHTML = `<b style=\"font-size:10.5pt;min-width:35px;\">${qNum}.</b>\n                          <span style=\"font-size:10.5pt;\">${wrapLatex(displayAns)}</span>`;\n        grid.appendChild(cell);\n    });\n\n    p.body.appendChild(grid);\n    if (window.MathJax?.typesetPromise) MathJax.typesetPromise([p.body]);\n}\n\nfunction makePage(area, type) {\n    pageCount++;\n    const page = document.createElement('div');\n    page.className = 'page';\n\n    const header = document.createElement('div');\n    header.className = 'page-header';\n    header.innerHTML = `<span>${AppState.title}</span><span>- ${pageCount} -</span>`;\n    page.appendChild(header);\n\n    if (type === 'ans') {\n        const body = document.createElement('div');\n        body.style.flex = '1';\n        page.appendChild(body);\n        area.appendChild(page);\n        return { page, body };\n    }\n\n    const grid = document.createElement('div');\n    grid.className = 'grid-container';\n\n    const left = document.createElement('div');\n    left.className = 'grid-col';\n\n    const right = document.createElement('div');\n    right.className = 'grid-col';\n\n    grid.appendChild(left);\n    grid.appendChild(right);\n    page.appendChild(grid);\n    area.appendChild(page);\n\n    return { page, cols: [left, right] };\n}\n\nfunction wrapLatex(text) {\n    return wrapLatexPreserveBlocks(text);\n}\n\nfunction wrapLatexPreserveBlocks(text) {\n    if (!text) return text;\n    let s = String(text);\n\n    s = s.replace(/\\^\\[([^\\]]+)\\]/g, '^{$1}').replace(/_\\[([^\\]]+)\\]/g, '_{$1}');\n    s = s.replace(//g, '(').replace(//g, ')').replace(//g, '');\n    s = s.replace(/²/g, '^2').replace(/³/g, '^3');\n    s = s.replace(/√\\s*\\(([^\\)]+)\\)/g, '\\\\sqrt{$1}').replace(/√\\s*([0-9a-zA-Z]+)/g, '\\\\sqrt{$1}');\n    s = s.replace(/sqrt\\(([^)]+)\\)/g, '\\\\sqrt{$1}').replace(/frac\\(([^,]+),([^)]+)\\)/g, '\\\\frac{$1}{$2}');\n    s = s.replace(/\\\\frac\\[([^\\]]+)\\]\\[([^\\]]+)\\]/g, '\\\\frac{$1}{$2}').replace(/\\\\dot\\[([^\\]]+)\\]/g, '\\\\dot{$1}');\n\n    if (/\\\\begin\\{(array|aligned|matrix|pmatrix|bmatrix|vmatrix|Vmatrix|cases)\\}/.test(s) || /\\\\multicolumn|\\\\cline|\\\\hline/.test(s)) {\n        return `$$${s}$$`;\n    }\n\n    if (/^\\s*\\$\\$[\\s\\S]*\\$\\$\\s*$/.test(s) || /^\\s*\\$[\\s\\S]*\\$\\s*$/.test(s)) return s;\n\n    const parts = s.split(/(<[^>]+>)/g);\n    return parts.map(p => {\n        if (!p) return '';\n        if (p.startsWith('<')) return p;\n\n        let t = p.replace(/\\\\n/g, '<br>').replace(/\\n/g, '<br>');\n        const trimmed = t.trim();\n\n        const hasKorean = /[가-힣]/.test(trimmed);\n        const hasDollar = /\\$/.test(trimmed);\n\n        const looksLikeMath =\n            !hasKorean &&\n            !hasDollar &&\n            (\n                /\\\\[a-zA-Z]+/.test(trimmed) ||\n                (/^[0-9a-zA-Z\\s\\+\\-\\*\\/\\=\\^\\_\\{\\}\\(\\)\\[\\]\\.,:;|\\\\]+$/.test(trimmed) && trimmed.length > 0)\n            );\n\n        if (looksLikeMath && !t.includes('<br>')) return `$${trimmed}$`;\n        return t;\n    }).join('');\n}\n\nfunction stripCite(text) {\n    if (!text) return text;\n    return text.replace(/【[^】]*】/g, '').trim();\n}\n\nfunction raf() {\n    return new Promise(r => requestAnimationFrame(r));\n}\n\nwindow.onload = init;\n</script>\n</body>\n</html>"
        }
    ]
}